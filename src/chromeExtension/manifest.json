{
    "name": "Moodcast",
    "description": "Displays a image and text for mental health support depending on the weather",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["geolocation"],
    "host_permissions": ["https://api.open-meteo.com/*"],
    "action": {
        "default_title": "MoodCast!",
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "cat.png",
        "32": "cat.png",
        "48": "cat.png",
        "128": "cat.png"
    },
    "content_scripts": []
}